# RRR rolling state — local execution memory, regenerated each phase.
# Never commit: every phase branch would otherwise collide with the last
# on these single-file states (the recurring STATE.md merge conflict).
.planning/STATE.md
.planning/workstreams/*/STATE.md
.planning/learnings.jsonl
# SUBMISSION.json is the OLD rolling submission marker — same collision class.
# The enforced marker is now per-phase: .planning/workstreams/<team>/submissions/<phase>.json
# (committed, read by scripts/check-submission.mjs). /rrr:submit-phase may still
# write SUBMISSION.json locally for RRR's advisory coordinate-merge; don't track it.
.planning/workstreams/*/SUBMISSION.json

# Playwright trace/screenshot output — local debug artifacts, never commit.
test-results/
playwright-report/
**/playwright-report/
**/test-results/
