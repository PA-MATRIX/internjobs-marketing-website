{
	"$schema": "node_modules/wrangler/config-schema.json",
	// v1.4 Phase 28 STARTUP-MCP-01..10: Startup MCP Server.
	// Exposes the Stainless-style search/execute/me/discover_actions MCP surface
	// at mcp.internjobs.ai. Founders install via:
	//   claude mcp add --transport http internjobs https://mcp.internjobs.ai/mcp --header "Authorization: Bearer {TOKEN}"
	"name": "internjobs-startup-mcp",
	"compatibility_date": "2025-11-28",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./workers/app.ts",
	"observability": { "enabled": true },
	// mcp.internjobs.ai custom domain — Workers Custom Domain auto-creates the DNS
	// record + provisions a Cloudflare-managed cert on first `wrangler deploy`.
	"routes": [
		{
			"pattern": "mcp.internjobs.ai",
			"custom_domain": true
		}
	],
	"vars": {
		// HTTPS URL of the internjobs-startup-api Fly proxy (Phase 28 Plan 01).
		// Not a secret — it's an internet-facing HTTPS hostname.
		"STARTUP_API_URL": "https://internjobs-startup-api.fly.dev"
	},
	// Workers AI binding (Phase 28 Plan 03). Used by lib/embed.ts to compute
	// 768-dim bge-base-en-v1.5 vectors directly via env.AI.run() — NO dependency
	// on the student app. CF bills per-neuron, not per-binding (free to declare).
	"ai": { "binding": "AI" }
	// Secrets (set via `wrangler secret put`):
	//   STARTUP_API_SECRET            — Bearer token for internjobs-startup-api proxy.
	//                                   Value is the 64-hex secret minted by 28-01;
	//                                   copy from /tmp/startup_api_secret.txt or
	//                                   (preferred long-term) Infisical /internjobs-ai/STARTUP_API_SECRET.
	//   STARTUP_MCP_ADMIN_SECRET      — Ridhi's admin endpoint auth (long random string).
	//                                   Used by Plan 28-04. Generate via
	//                                   `openssl rand -hex 32` and persist in Infisical
	//                                   /internjobs-ai/STARTUP_MCP_ADMIN_SECRET.
	//   TELNYX_API_KEY                — (optional, Plan 28-04) Telnyx API key for
	//                                   SMS delivery of the per-founder install
	//                                   snippet. If unset, the admin endpoint logs
	//                                   the snippet and returns it in the response
	//                                   body so Ridhi can SMS it manually.
	//                                   Infisical /internjobs-ai/TELNYX_API_KEY.
	//   TELNYX_FROM_NUMBER            — (optional, Plan 28-04) E.164 phone number
	//                                   to send install SMSes from (e.g. +18005551234).
	//                                   Required if TELNYX_API_KEY is set.
	//                                   Infisical /internjobs-ai/TELNYX_FROM_NUMBER.
	//   TELNYX_MESSAGING_PROFILE_ID   — (optional) Telnyx messaging profile id.
	//                                   Recommended for US production deliverability.
}
