# ---------------------------------------------------------------------------
# mac-bridge configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values. The .env file is loaded by
# `node --env-file=.env` at startup (see the npm scripts in package.json).

# HTTP listener — the local port + host that Fly will hit at /v1/send.
# Defaults are fine for the standard Cloudflare-Tunnel-fronted deploy.
BRIDGE_PORT=8787
BRIDGE_HOST=127.0.0.1
BRIDGE_LOG_LEVEL=info

# Shared HMAC secret with Fly's /webhooks/mac-bridge handler. Both sides of
# the bridge wire (inbound + outbound) sign / verify with this. Generate
# with: openssl rand -hex 32
BRIDGE_HMAC_SECRET=replace-with-32-byte-hex

# Where inbound iMessage events get POSTed. Same URL as Fly's webhook route.
BRIDGE_OUTBOUND_WEBHOOK_URL=https://app.internjobs.ai/webhooks/mac-bridge

# ---------------------------------------------------------------------------
# BlueBubbles (replaces spectrum-ts local mode as of Phase 07b)
# ---------------------------------------------------------------------------
# BlueBubbles Server runs on the same Mac mini and exposes Messages.app's
# internals via HTTP + Socket.IO. mac-bridge subscribes to the new-message
# stream for inbound, and POSTs to /api/v1/message/text for outbound.
#
# 1. Install BlueBubbles-Server-macOS.dmg
# 2. Grant Full Disk Access + Automation + Accessibility (see setup.sh)
# 3. Install the Private API helper (Settings → Private API → Install)
# 4. Set a server password in the BlueBubbles UI and paste it below

BLUEBUBBLES_URL=http://127.0.0.1:1234
BLUEBUBBLES_PASSWORD=replace-with-the-password-you-set-in-bluebubbles-ui
