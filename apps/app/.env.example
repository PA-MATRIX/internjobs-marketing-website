# apps/app environment example (v1.2 Phase 04 baseline)
#
# Production secrets live in Infisical (project 26995afd, env=prod,
# path=/internjobs-ai) and are imported into Fly via:
#   flyctl secrets import --app internjobs-ai-student-app
#
# This file documents the keys the app reads at runtime. Do NOT commit a
# real .env. Use this only as a reference / for local dev with a stub
# DATABASE_URL.

# --- Core --------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_URL=http://localhost:3000
APP_SESSION_SECRET=replace-with-a-long-random-value

# --- Database (Neon) ---------------------------------------------------------
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# --- Clerk -------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=
CLERK_SIGN_UP_URL=
CLERK_JWKS_URL=

# --- Active SMS/iMessage path: Mac bridge + BlueBubbles ----------------------
SMS_PROVIDER=mac-bridge
AGENT_NUMBER=+14063210019
BRIDGE_URL=https://bridge.internjobs.ai
BRIDGE_HMAC_SECRET=

# --- Legacy Spectrum / Photon webhook compatibility --------------------------
# Do not use PHOTON_FROM_NUMBER for QR pairing. The visible student number is
# AGENT_NUMBER above. Keep these only if replaying old Photon webhook tests.
PHOTON_PROJECT_ID=
PHOTON_API_BASE_URL=
PHOTON_API_TOKEN=
PHOTON_FROM_NUMBER=
PHOTON_WEBHOOK_SECRET=
ENABLE_SPECTRUM_LISTENER=false

# --- Email channel (v1.2 Phase 03) -------------------------------------------
EMAIL_WORKER_SECRET=
RESEND_API_KEY=

# --- Mastra agent core (v1.2 Phase 04 - AGENT-01/02/03) ----------------------
# OPENAI_API_KEY drives both embeddings (text-embedding-3-small) and the
# draft LLM (gpt-4o-mini by default). Without it the workflow falls back to a
# deterministic canned draft so the operator queue stays unblocked.
OPENAI_API_KEY=

# Optional: override the draft model. Default 'gpt-4o-mini'.
# AGENT_MODEL=gpt-4o-mini

# USE_VECTOR_MATCH toggles the workflow match step between keyword overlap
# (default) and pgvector cosine. Setting true without OPENAI_API_KEY or
# without a stored student embedding silently falls back to keyword - no
# crash. Phase 04 step 7 verifies all three scenarios.
USE_VECTOR_MATCH=false

# Test-only: when set to 'stub', the workflow's LLM call returns a canned
# string and the embeddings module returns a deterministic vector. Used by
# scripts/smoke-mastra.mjs so the workflow can be exercised end-to-end
# without burning OpenAI quota. Never set in production.
# LLM_PROVIDER=stub
# EMBED_PROVIDER=stub

# --- Local dev convenience ---------------------------------------------------
ENABLE_DEV_AUTH=true
