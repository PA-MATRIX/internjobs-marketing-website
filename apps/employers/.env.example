# apps/startups — environment variables
#
# Canonical store: Infisical org 2c12f042..., project 26995afd..., env=prod,
# path=/internjobs-ai. The keys below are LOCAL DEV pointers — the values
# themselves never live in this file (or any other tracked file).

# ─── Vite build-time (PUBLIC — bundled into static JS) ───────────────────────
#
# Vite uses the VITE_* prefix for build-time client env. The Clerk publishable
# key is public by design (it identifies the Clerk app and is meant to be
# visible in browser source). Infisical stores it under the historical name
# STARTUPS_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY — at deploy time we re-export it
# as VITE_CLERK_PUBLISHABLE_KEY so vite picks it up.
#
# Local dev: copy from Infisical into .env.local (gitignored).
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...   # from Infisical STARTUPS_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY

# ─── Pages Function runtime (SECRET — never in Vite bundle) ──────────────────
#
# These are set via `wrangler pages secret put <NAME> --project-name internjobs-startups`
# and are only accessible from functions/api/[[path]].ts (CF Pages Functions
# runtime). They MUST NOT be prefixed with VITE_ or they would leak into the
# public JS bundle.
STARTUP_API_URL=https://internjobs-startup-api.fly.dev   # Fly proxy URL (Pages Function)
STARTUP_API_SECRET=...                                   # Bearer secret for Fly proxy (Pages Function)
