{
  "name": "internjobs-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "!apps/agentic-inbox",
    "!apps/parrot"
  ],
  "scripts": {
    "dev": "npm run dev:marketing",
    "build": "npm run build:marketing && npm run build:app",
    "verify": "npm run verify:marketing:dist && npm run build:app",
    "dev:marketing": "npm --workspace @internjobs/marketing run dev",
    "build:marketing": "npm --workspace @internjobs/marketing run build",
    "preview:marketing": "npm --workspace @internjobs/marketing run preview",
    "verify:marketing:dist": "npm --workspace @internjobs/marketing run verify:dist",
    "verify:marketing:production": "npm --workspace @internjobs/marketing run verify:production",
    "deploy:pages": "npm --workspace @internjobs/marketing run deploy:pages",
    "dev:app": "npm --workspace @internjobs/app run dev",
    "start:app": "npm --workspace @internjobs/app run start",
    "build:app": "npm --workspace @internjobs/app run build",
    "smoke:parrot-graph": "node infra/graph-api/smoke.mjs"
  }
}
